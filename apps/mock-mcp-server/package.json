{
  "name": "@renderprotocol/mock-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:alpha": "cross-env MOCK_AGENT_NAME=alpha PORT=4717 tsx watch src/index.ts",
    "dev:beta": "cross-env MOCK_AGENT_NAME=beta PORT=4718 MOCK_TOOLS=lookup,get_alerts,get_recent_events tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@renderprotocol/protocol-types": "workspace:*",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
